# =============================================================================
# Chapel Attendance System — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked with <CHANGE_THIS>
#   3. Never commit the .env file — it is in .gitignore
# =============================================================================


# =============================================================================
# DJANGO CORE
# =============================================================================

# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=<CHANGE_THIS>

# Always False in production — True only for local development
DJANGO_DEBUG=False

# Your domain — comma-separated, no spaces, no http://
# Example: chapel.youruniversity.edu,www.chapel.youruniversity.edu
DJANGO_ALLOWED_HOSTS=<CHANGE_THIS>

# Your frontend origin — full URL with protocol, no trailing slash
# Example: https://chapel.youruniversity.edu
CORS_ALLOWED_ORIGINS=<CHANGE_THIS>


# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
DB_NAME=chapel_attendance
DB_USER=postgres

# Generate a strong password with:  openssl rand -base64 32
DB_PASSWORD=<CHANGE_THIS>

# In Docker: use the service name 'db'. On bare-metal: use localhost
DB_HOST=db
DB_PORT=5432


# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

# Your production domain — no https://, no trailing slash
# Example: chapel.youruniversity.edu
NEXT_PUBLIC_APP_DOMAIN=<CHANGE_THIS>

# Full public URL — used by the frontend for API calls
# Example: https://chapel.youruniversity.edu
NEXT_PUBLIC_API_URL=<CHANGE_THIS>

# Internal Docker network URL for Next.js → Django (server-side rewrites)
# Do not change unless you rename the backend service in docker-compose.yml
BACKEND_INTERNAL_URL=http://backend:8000


# =============================================================================
# INSIGHTFACE / FACE RECOGNITION
# =============================================================================

# Model pack: buffalo_l (best, ~500 MB) | buffalo_m (~150 MB) | buffalo_s (~90 MB)
INSIGHTFACE_MODEL_NAME=buffalo_l

# Cosine DISTANCE threshold — lower = stricter. ArcFace default is 0.40.
# Raise to 0.45 for fewer false rejects; lower to 0.35 for stricter matching.
INSIGHTFACE_MATCH_THRESHOLD=0.40

# Minimum RetinaFace detection confidence (0.0–1.0).
# Faces below this are blurry/poorly lit and will be rejected.
INSIGHTFACE_DET_SCORE_MIN=0.50

# Minimum face bounding-box size in pixels.
# Faces smaller than this are rejected as "too far from camera".
INSIGHTFACE_MIN_FACE_PX=80


# =============================================================================
# OPTIONAL TUNING
# =============================================================================

# Fuzzy name duplicate detection threshold (0-100)
FUZZY_NAME_MATCH_THRESHOLD=85

# How many hours a matric-update token stays valid
MATRIC_UPDATE_TOKEN_EXPIRY_HOURS=48
